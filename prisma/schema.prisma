generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  activities    Activity[]
  sessions      Session[]
  tickets       Ticket[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Ticket {
  id              String           @id @default(cuid())
  title           String
  description     String
  status          TicketStatus     @default(OPEN)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userId          String
  category        TicketCategory?
  priority        TicketPriority?
  userPriority    TicketPriority?
  aiPriority      TicketPriority?
  sentiment       TicketSentiment?
  suggestedReply  String?
  aiSummary       String?
  keyIssues       String?          // comma-separated or text issues list
  recommendedTeam String?
  slaBreached          Boolean               @default(false)
  escalatedAt          DateTime?
  source               TicketSource          @default(WEB)
  whatsAppConversation WhatsAppConversation?
  activities           Activity[]
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([priority])
  @@index([aiPriority])
  @@index([slaBreached])
  @@index([source])
}

model Activity {
  id        String   @id @default(cuid())
  action    String
  createdAt DateTime @default(now())
  ticketId  String
  userId    String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ticketId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketCategory {
  BILLING
  REFUND
  TECHNICAL
  DELIVERY
  ACCOUNT
  ACCOUNT_ACCESS
  SUBSCRIPTION
  GENERAL_INQUIRY
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum TicketSource {
  WEB
  WHATSAPP
}

enum WhatsAppConversationStatus {
  ACTIVE
  ESCALATED
  RESOLVED
}

enum MessageSender {
  CUSTOMER
  AI
  SYSTEM
  AGENT
}

model WhatsAppConversation {
  id           String                     @id @default(cuid())
  phoneNumber  String                     @unique
  customerName String?
  status       WhatsAppConversationStatus @default(ACTIVE)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  ticketId     String?                    @unique
  ticket       Ticket?                    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  messages     WhatsAppMessage[]

  @@index([status])
}

model WhatsAppMessage {
  id             String               @id @default(cuid())
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         MessageSender
  text           String
  createdAt      DateTime             @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

